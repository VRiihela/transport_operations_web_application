generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Admin
  Dispatcher
  Driver
}

enum AuditEvent {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  TOKEN_REFRESH
  TOKEN_REUSE_DETECTED
}

enum JobStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

enum JobType {
  DELIVERY
  PICKUP
  DELIVERY_AND_PICKUP
  INSTALLATION
  SERVICE
  COMBINED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens     RefreshToken[]
  assignedJobs      Job[]              @relation("AssignedJobs")
  createdJobs       Job[]              @relation("CreatedJobs")
  completionReports CompletionReport[]
  createdTeams      Team[]             @relation("CreatedTeams")
  teamMemberships   TeamMember[]       @relation("TeamMemberships")

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String     @id @default(cuid())
  event     AuditEvent
  userId    String?
  ip        String     @db.VarChar(45)
  userAgent String?    @db.VarChar(500)
  metadata  Json?
  createdAt DateTime   @default(now())

  @@map("audit_logs")
}

model Job {
  id               String    @id @default(cuid())
  title            String    @db.VarChar(255)
  description      String?
  status           JobStatus @default(DRAFT)
  jobType          JobType   @default(DELIVERY)
  assignedDriverId String?
  teamId           String?
  customerId       String?
  sortOrder        Int       @default(0)
  services         String?
  scheduledAt      DateTime?
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  schedulingNote   String?
  driverNotes      String?
  location         String?   @db.VarChar(255)
  notes            String?
  street              String?   @db.VarChar(255)
  houseNumber         String?   @db.VarChar(50)
  stair               String?   @db.VarChar(50)
  postalCode          String?   @db.VarChar(20)
  city                String?   @db.VarChar(255)
  deliveryStreet      String?   @db.VarChar(255)
  deliveryHouseNumber String?   @db.VarChar(50)
  deliveryStair       String?   @db.VarChar(50)
  deliveryPostalCode  String?   @db.VarChar(20)
  deliveryCity        String?   @db.VarChar(255)
  pickupStreet     String?
  pickupPostalCode String?
  pickupCity       String?
  floorStair       String?
  doorCode         String?
  accessNotes      String?
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  assignedDriver   User?             @relation("AssignedJobs", fields: [assignedDriverId], references: [id])
  createdBy        User              @relation("CreatedJobs", fields: [createdById], references: [id])
  completionReport CompletionReport?
  team             Team?             @relation(fields: [teamId], references: [id])
  customer         Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedDriverId])
  @@index([createdById])
  @@map("jobs")
}

model CompletionReport {
  id                String    @id @default(cuid())
  jobId             String    @unique
  workDescription   String
  actualStart       DateTime
  actualEnd         DateTime
  totalHours        Float
  customerName      String
  customerSignature String
  approvedAt        DateTime?
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  job       Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@map("completion_reports")
}

model Team {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  date        DateTime
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User         @relation("CreatedTeams", fields: [createdById], references: [id])
  members   TeamMember[]
  jobs      Job[]

  @@index([date])
  @@map("teams")
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation("TeamMemberships", fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@map("team_members")
}

enum CustomerType {
  PRIVATE
  BUSINESS
}

model Customer {
  id              String       @id @default(cuid())
  name            String
  phone           String       @unique
  email           String?
  type            CustomerType
  companyName     String?
  referenceNumber String?
  createdAt       DateTime     @default(now())

  jobs Job[]

  @@index([phone])
  @@map("customers")
}
