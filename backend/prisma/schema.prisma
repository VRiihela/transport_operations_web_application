generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Admin
  Dispatcher
  Driver
}

enum AuditEvent {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  TOKEN_REFRESH
  TOKEN_REUSE_DETECTED
}

enum JobStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  assignedJobs  Job[]          @relation("AssignedJobs")
  createdJobs   Job[]          @relation("CreatedJobs")

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String     @id @default(cuid())
  event     AuditEvent
  userId    String?
  ip        String     @db.VarChar(45)
  userAgent String?    @db.VarChar(500)
  metadata  Json?
  createdAt DateTime   @default(now())

  @@map("audit_logs")
}

model Job {
  id               String    @id @default(cuid())
  title            String    @db.VarChar(255)
  description      String?
  status           JobStatus @default(DRAFT)
  assignedDriverId String?
  scheduledAt      DateTime?
  location         String?   @db.VarChar(255)
  notes            String?
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  assignedDriver User? @relation("AssignedJobs", fields: [assignedDriverId], references: [id])
  createdBy      User  @relation("CreatedJobs", fields: [createdById], references: [id])

  @@index([status])
  @@index([assignedDriverId])
  @@index([createdById])
  @@map("jobs")
}
